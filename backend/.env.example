PORT=8787
NODE_ENV=production
DATABASE_URL=postgresql://user:pass@localhost:5432/menuvista
JWT_SECRET=change-this-secret

# Comma-separated frontend origins, or * during development
CORS_ORIGIN=*

# sandbox | production
MPESA_ENV=sandbox

# Safaricom Daraja credentials
MPESA_CONSUMER_KEY=wqBD641HvJK5xSp3h8lBNl2A1vhUGur2f8rNHmNsT5F4ApUnvS39MslX0EFBbyPp
MPESA_CONSUMER_SECRET=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_SHORTCODE=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_PASSKEY=174379

# Public URL that Safaricom can call after STK prompt
MPESA_CALLBACK_URL=https://your-backend.example.com/payments/callback

# Usually CustomerPayBillOnline for paybill, or CustomerBuyGoodsOnline for till
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline

# Optional override; defaults to MPESA_SHORTCODE
MPESA_PARTY_B=

# Supabase Storage (for image and GLB uploads)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=menuvista-assets
# Optional explicit public base URL. Default:
# {SUPABASE_URL}/storage/v1/object/public
SUPABASE_STORAGE_PUBLIC_URL=
