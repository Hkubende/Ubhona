{
  "name": "ubhona-v4",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "backend:start": "node backend/server.mjs",
    "backend:dev": "node --watch backend/server.mjs",
    "backend:test": "npm --prefix backend run test",
    "check:mpesa": "node scripts/check-mpesa-backend.mjs",
    "stk:mv4": "node scripts/stkpush-mv4.mjs",
    "validate:dishes": "node scripts/validate-dishes.mjs",
    "validate:assets": "node scripts/validate-dishes-assets.mjs",
    "validate:data": "npm run validate:dishes && npm run validate:assets",
    "prebuild": "npm run validate:data",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "codex": "codex",
    "check:all": "npm run validate:data && npm run validate:assets && npm run validate:dishes && npm run build",
    "precommit": "npm run check:all"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^5.1.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "chrome-devtools-mcp": "^0.20.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "lightningcss": "^1.32.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.1.12"
  }
}
